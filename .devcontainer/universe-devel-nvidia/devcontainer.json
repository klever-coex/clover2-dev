{
  "name": "clover2-dev:universe-devel (NVIDIA)",
  "dockerComposeFile": [
    "../../docker/devcontainer/common.compose.yaml",
    "../../docker/devcontainer/universe-devel.compose.yaml",
    "../../docker/devcontainer/universe-devel-nvidia.compose.yaml",
  ],
  "service": "clover2-dev-devel",
  "workspaceFolder": "/home/dev/clover2-dev",
  "containerUser": "root",
  "remoteUser": "dev",
  "overrideCommand": false,
  "initializeCommand": "xhost +local:docker",
  "postCreateCommand": "echo 'source /opt/ros/$ROS_DISTRO/setup.bash' >> ~/.bashrc",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "betwo.b2-catkin-tools",
        "DotJoshJohnson.xml",
        "ms-azuretools.vscode-docker",
        "ranch-hand-robotics.rde-pack",
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "redhat.vscode-yaml",
        "yzhang.markdown-all-in-one",
        "zachflower.uncrustify",
      ]
    }
  },
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "NVIDIA_DRIVER_CAPABILITIES": "all"
  }
}